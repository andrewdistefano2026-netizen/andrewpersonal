function Button({ children, onClick, variant = "default", className = "", type = "button" }) {
  const base = "inline-flex items-center justify-center px-4 py-2 text-sm font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-slate-400";
  const styles =
    variant === "outline"
      ? "border border-white/30 bg-transparent text-white hover:bg-white/10"
      : variant === "ghost"
      ? "text-slate-700 hover:bg-slate-100"
      : "bg-slate-950 text-white hover:bg-slate-800";

  return (
    <button type={type} onClick={onClick} className={`${base} ${styles} ${className}`}>
      {children}
    </button>
  );
}

function Card({ children, className = "" }) {
  return <div className={`bg-white ${className}`}>{children}</div>;
}

function CardContent({ children, className = "" }) {
  return <div className={className}>{children}</div>;
}

