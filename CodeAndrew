function runSelfTests() {
  const pageIds = pages.map((page) => page.id);
  console.assert(pageIds.includes("home"), "Expected Home page to exist");
  console.assert(pageIds.includes("experience"), "Expected Work Experience page to exist");
  console.assert(pageIds.includes("activities"), "Expected Activities page to exist");
  console.assert(experience.length >= 4, "Expected at least four work experiences from the resume");
  console.assert(activities.length >= 4, "Expected at least four activity/honor sections from the resume");
  console.assert(
    experience.every((job) => job.company && job.role && job.description),
    "Every experience should have company, role, and description"
  );
  console.assert(
    activities.every((item) => item.title && item.role && item.description && item.icon && item.tag),
    "Every activity should have title, role, description, icon, and tag"
  );
  console.assert(
    typeof HEADSHOT_SRC === "string" && HEADSHOT_SRC.startsWith("http"),
    "Expected embedded headshot image data"
  );
  console.assert(pages.every((page) => page.id && page.label), "Every navigation page should have an id and label");
}
